// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  username      String?  @unique
  bio           String?

  reccCount     Int @default(0)
  reccs         Recc[]
  comments      Comment[]
  likes         Like[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Recc {
  id          String @id @default(cuid())

  title       String
  description String?
  url         String?

  type        String

  userId      String
  user        User @relation(fields: [userId], references: [id])

  likeCount   Int @default(0)
  likes       Like[]

  commentCount Int @default(0)
  comments     Comment[]

  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Comment {
  id        String @id @default(cuid())

  content   String

  userId    String
  user      User @relation(fields: [userId], references: [id])

  reccId    String
  recc      Recc @relation(fields: [reccId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Like {
  userId    String
  reccId    String

  user      User @relation(fields: [userId], references: [id])
  recc      Recc @relation(fields: [reccId], references: [id], onDelete: Cascade)

  @@id([userId, reccId])
}